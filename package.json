{
  "name": "chromium-ocr-wrapper",
  "version": "0.1.0",
  "description": "CLI tool that converts image-only PDFs to searchable PDFs using Chrome's built-in OCR (PDFSearchify/Screen AI)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "chromium-ocr": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ocr",
    "pdf",
    "chromium",
    "searchable-pdf",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.60.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-v8": "^3.1.0",
    "canvas": "^3.2.3",
    "eslint": "^9.25.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
