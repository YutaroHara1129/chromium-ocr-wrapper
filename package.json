{
  "name": "chromium-ocr-wrapper",
  "version": "0.1.0-beta.0",
  "description": "CLI tool that converts image-only PDFs to searchable PDFs using Chrome's built-in OCR (PDFSearchify/Screen AI)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "chromium-ocr": "dist/cli.js",
    "chromium-ocr-wrapper": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "release:check": "npm run lint && npm run typecheck && npm test && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "ocr",
    "pdf",
    "chromium",
    "chrome",
    "screen-ai",
    "searchable-pdf",
    "pdf-ocr",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yutarohara/chromium-ocr-wrapper.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-v8": "^3.1.0",
    "canvas": "^3.2.3",
    "eslint": "^9.25.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
